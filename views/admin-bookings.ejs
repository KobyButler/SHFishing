<%- include('partials/head') %>

<section class="section">
  <div class="container">
    <h2>Booking Requests</h2>
    <%- include('partials/admin-nav') %>
      <% if (updated) { %>
        <div class="notice">Booking updated successfully.</div>
      <% } %>
      <div class="admin-tabs" data-tabs>
        <a class="tab <%= tab === 'pending' ? 'active' : '' %>" href="/admin/bookings?tab=pending">Open Requests (<%= pending.length %>)</a>
        <a class="tab <%= tab === 'confirmed' ? 'active' : '' %>" href="/admin/bookings?tab=confirmed">Confirmed Trips (<%= confirmed.length %>)</a>
        <a class="tab <%= tab === 'cancelled' ? 'active' : '' %>" href="/admin/bookings?tab=cancelled">Closed Requests (<%= cancelled.length %>)</a>
      </div>
      <div class="card">
        <% const list = tab === 'pending' ? pending : tab === 'confirmed' ? confirmed : cancelled; %>
        <% if (list.length === 0) { %>
          <p>No booking requests in this view.</p>
        <% } %>
        <% list.forEach((booking) => { %>
          <form method="post" action="/admin/bookings/<%= booking.id %>/update" style="margin-bottom:24px;">
            <input type="hidden" name="csrf" value="<%= csrfToken %>" />
            <h3>#<%= booking.id %> - <%= booking.service_name %></h3>
            <p><strong>Guest:</strong> <%= booking.name %> | <%= booking.email %> | <%= booking.phone %></p>
            <p><strong>Date:</strong> <%= booking.date %> at <%= booking.time %> | <strong>Guests:</strong> <%= booking.guests %></p>
            <% if (booking.notes) { %>
              <p><strong>Notes:</strong> <%= booking.notes %></p>
            <% } %>
            <div class="form-group">
              <label>Status</label>
              <select name="status">
                <option value="pending" <%= booking.status === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="confirmed" <%= booking.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                <option value="cancelled" <%= booking.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
              </select>
            </div>
            <div class="form-group">
              <label>Proposed Date (optional)</label>
              <input type="date" name="proposedDate" value="<%= booking.proposed_date || '' %>" />
            </div>
            <div class="form-group">
              <label>Proposed Time (optional)</label>
              <input name="proposedTime" value="<%= booking.proposed_time || '' %>" />
            </div>
            <div class="form-group">
              <label>Admin Notes</label>
              <textarea name="adminNotes"><%= booking.admin_notes || '' %></textarea>
            </div>
            <label>
              <input type="checkbox" name="notify" /> Notify customer by email
            </label>
            <div style="margin-top:12px;">
              <button class="button" type="submit">Save Update</button>
            </div>
          </form>
        <% }) %>
      </div>
    <%- include('partials/admin-nav-end') %>
  </div>
</section>

<%- include('partials/footer') %>
