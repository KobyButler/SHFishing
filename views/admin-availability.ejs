<%- include('partials/head') %>

<section class="section">
  <div class="container">
    <h1>Availability</h1>
    <%- include('partials/admin-nav') %>
      <div class="card">
        <h3>Block Out Dates or Times</h3>
        <form method="post" action="/admin/availability">
          <input type="hidden" name="csrf" value="<%= csrfToken %>" />
          <div class="form-group">
            <label>Service</label>
            <select name="serviceId" required>
              <% services.forEach((service) => { %>
                <option value="<%= service.id %>"><%= service.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Date</label>
            <input type="date" name="date" required />
          </div>
          <div class="form-group">
            <label>Start Time (24h)</label>
            <input name="time" placeholder="07:00" required />
          </div>
          <div class="form-group">
            <label>Note (optional)</label>
            <input name="note" />
          </div>
          <button class="button" type="submit">Block Time</button>
        </form>
      </div>

      <div class="card" style="margin-top:24px;">
        <h3>Blocked Slots</h3>
        <% if (blocks.length === 0) { %>
          <p>No blocked times yet.</p>
        <% } %>
        <% blocks.forEach((block) => { %>
          <div style="margin-bottom:12px;">
            <strong><%= block.service_name %></strong> - <%= block.date %> at <%= block.time %>
            <% if (block.note) { %>
              <span class="badge"><%= block.note %></span>
            <% } %>
            <form method="post" action="/admin/availability/<%= block.id %>/delete" style="display:inline;">
              <input type="hidden" name="csrf" value="<%= csrfToken %>" />
              <button class="button secondary" type="submit">Remove</button>
            </form>
          </div>
        <% }) %>
      </div>
    <%- include('partials/admin-nav-end') %>
  </div>
</section>

<%- include('partials/footer') %>
