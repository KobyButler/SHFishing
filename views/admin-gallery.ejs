<%- include('partials/head') %>

<section class="section">
  <div class="container">
    <h2>Gallery Manager</h2>
    <%- include('partials/admin-nav') %>
      <div class="card">
        <h3>Add Photo</h3>
        <form method="post" action="/admin/gallery" enctype="multipart/form-data">
          <input type="hidden" name="csrf" value="<%= csrfToken %>" />
          <div class="form-group">
            <label>Image File</label>
            <input type="file" name="image" accept="image/*" required />
          </div>
          <div class="form-group">
            <label>Caption (optional)</label>
            <input name="caption" />
          </div>
          <button class="button" type="submit">Upload</button>
        </form>
      </div>

      <div class="card" style="margin-top:24px;">
        <h3>Current Photos</h3>
        <div class="gallery-grid">
          <% images.forEach((img) => { %>
            <div class="gallery-item">
              <img src="/uploads/gallery/<%= img.filename %>" alt="<%= img.caption || 'Gallery image' %>" />
              <span><%= img.caption || 'No caption' %></span>
              <form method="post" action="/admin/gallery/<%= img.id %>/delete">
                <input type="hidden" name="csrf" value="<%= csrfToken %>" />
                <button class="button secondary" type="submit">Delete</button>
              </form>
            </div>
          <% }) %>
        </div>
      </div>
    <%- include('partials/admin-nav-end') %>
  </div>
</section>

<%- include('partials/footer') %>
