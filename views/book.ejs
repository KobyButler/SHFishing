<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section">
  <div class="container">
    <h1>Book Your Trip</h1>
    <p class="lead">Choose a package below. For custom kids trips, contact us directly for trip details.</p>
    <div class="card-grid">
      <% services.forEach((service) => { %>
        <div class="card">
          <h3><%= service.name %></h3>
          <p><span class="badge"><%= service.duration_hours > 0 ? `${service.duration_hours} hours` : 'Custom duration' %></span></p>
          <p><%= service.description %></p>
          <p><strong><%= service.price > 0 ? `$${service.price}` : 'Contact for more info' %></strong></p>
          <% if (service.price > 0) { %>
            <a class="button" href="/book/<%= service.id %>">Request Availability</a>
          <% } else { %>
            <a class="button" href="/#contact">Contact for Details</a>
          <% } %>
          <% if (member) { %>
            <form method="post" action="/member/save/<%= service.id %>" style="margin-top:10px;">
              <input type="hidden" name="csrf" value="<%= csrfToken %>" />
              <button class="button secondary" type="submit">Save Trip</button>
            </form>
          <% } %>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
