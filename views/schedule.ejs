<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section">
  <div class="container">
    <p class="section-kicker">Booking Flow</p>
    <h1>Schedule Your Trip</h1>
    <p class="lead">Request availability for <strong><%= service.name %></strong>. Select a date and start time, then complete the request form.</p>
    <div class="booking-steps" aria-label="Booking steps">
      <div class="step-item">
        <span class="step-index">1</span>
        <span>Select date and time</span>
      </div>
      <div class="step-item">
        <span class="step-index">2</span>
        <span>Share trip details</span>
      </div>
      <div class="step-item">
        <span class="step-index">3</span>
        <span>Get confirmation</span>
      </div>
    </div>
    <% if (settings.paymentsEnabled === 'true') { %>
      <div class="notice">Payments are enabled. You will receive a secure payment link after your request is confirmed.</div>
    <% } %>
    <div class="card-grid">
      <div class="calendar" data-calendar data-service-id="<%= service.id %>">
        <div class="calendar-header">
          <button class="button secondary" type="button" data-prev-month>Previous</button>
          <strong data-month-label></strong>
          <button class="button secondary" type="button" data-next-month>Next</button>
        </div>
        <div class="calendar-grid"></div>
        <div style="margin-top: 16px;">
          <strong>Available start times</strong>
          <div class="timeslot-list" data-timeslots></div>
        </div>
      </div>
      <div class="card">
        <h3>Request Availability</h3>
        <p class="field-hint" data-selected-slot aria-live="polite">Step 1: Select a date and start time to continue.</p>
        <form method="post" action="/book/<%= service.id %>/request" data-booking-form>
          <input type="hidden" name="csrf" value="<%= csrfToken %>" />
          <input type="text" name="company" style="display:none" tabindex="-1" autocomplete="off" />
          <input type="hidden" name="date" required />
          <input type="hidden" name="time" required />
          <div class="form-group">
            <label for="name">Name</label>
            <input id="name" name="name" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required />
          </div>
          <div class="form-group">
            <label for="phone">Phone</label>
            <input id="phone" name="phone" required />
          </div>
          <div class="form-group">
            <label for="guests">Number of Guests</label>
            <input id="guests" name="guests" type="number" min="1" max="12" required />
          </div>
          <div class="form-group">
            <label for="notes">Notes</label>
            <textarea id="notes" name="notes" placeholder="What do you want to target? Any special requests?"></textarea>
          </div>
          <button class="button" type="submit">Request Availability</button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
