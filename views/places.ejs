<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section">
  <div class="container">
    <p class="section-kicker">Trip Planning</p>
    <h1>Places to Stay and Eat</h1>
    <p class="lead">Local favorites near the marina to make trip planning easy.</p>

    <div class="card">
      <h3>Places to Stay</h3>
      <div class="place-list">
        <% lodgingList.forEach((place) => { %>
          <article class="place-item">
            <strong><%= place.name %></strong>
            <p><%= place.description %></p>
            <% if (place.url) { %>
              <a class="button secondary" href="<%= place.url %>" target="_blank" rel="noopener">Go to Site</a>
            <% } %>
          </article>
        <% }) %>
        <% if (lodgingList.length === 0) { %>
          <p>Lodging recommendations coming soon.</p>
        <% } %>
      </div>
    </div>

    <% if (campingList.length > 0) { %>
      <div class="card" style="margin-top: var(--space-6);">
        <h3>Camping Near the Lake</h3>
        <ul>
          <% campingList.forEach((spot) => { %>
            <li><%= spot %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
