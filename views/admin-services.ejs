<%- include('partials/head') %>

<section class="section">
  <div class="container">
    <h1>Services</h1>
    <%- include('partials/admin-nav') %>
      <div class="card">
        <h3>Add Service</h3>
        <form method="post" action="/admin/services">
          <input type="hidden" name="csrf" value="<%= csrfToken %>" />
          <div class="form-group">
            <label>Name</label>
            <input name="name" required />
          </div>
          <div class="form-group">
            <label>Description</label>
            <textarea name="description" required></textarea>
          </div>
          <div class="form-group">
            <label>Duration (hours)</label>
            <input type="number" name="duration" min="0" required />
          </div>
          <div class="form-group">
            <label>Price (USD)</label>
            <input type="number" name="price" min="0" required />
          </div>
          <div class="form-group">
            <label>Start Times (comma-separated, 24h)</label>
            <input name="startTimes" placeholder="05:30, 06:30, 07:30" required />
          </div>
          <button class="button" type="submit">Add Service</button>
        </form>
      </div>

      <div class="card" style="margin-top:24px;">
        <h3>Existing Services</h3>
        <% services.forEach((service) => { %>
          <form method="post" action="/admin/services/<%= service.id %>/update" style="margin-bottom:18px;">
            <input type="hidden" name="csrf" value="<%= csrfToken %>" />
            <div class="form-group">
              <label>Name</label>
              <input name="name" value="<%= service.name %>" required />
            </div>
            <div class="form-group">
              <label>Description</label>
              <textarea name="description" required><%= service.description %></textarea>
            </div>
            <div class="form-group">
              <label>Duration (hours)</label>
              <input type="number" name="duration" min="0" value="<%= service.duration_hours %>" required />
            </div>
            <div class="form-group">
              <label>Price (USD)</label>
              <input type="number" name="price" min="0" value="<%= service.price %>" required />
            </div>
            <div class="form-group">
              <label>Start Times (comma-separated)</label>
              <input name="startTimes" value="<%= JSON.parse(service.start_times_json).join(', ') %>" required />
            </div>
            <button class="button" type="submit">Update</button>
            <button class="button secondary" type="submit" formaction="/admin/services/<%= service.id %>/delete">Delete</button>
          </form>
        <% }) %>
      </div>
    <%- include('partials/admin-nav-end') %>
  </div>
</section>

<%- include('partials/footer') %>
